{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "node bot.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "variables": {
    "BOT_NAME": {
      "description": "Name of your Minecraft bot",
      "required": true
    },
    "SERVER_IP": {
      "description": "Minecraft server IP address",
      "required": true
    },
    "SERVER_PORT": {
      "value": "25565",
      "description": "Server port"
    }
  }
}
